# Local-only defaults for the observability bootstrap stack.
# Do not reuse these values in shared or production environments.

PHOENIX_POSTGRES_USER=phoenix
PHOENIX_POSTGRES_PASSWORD=phoenix_local_only
PHOENIX_POSTGRES_DB=phoenix
PHOENIX_POSTGRES_GRAFANA_USER=grafana_ro
PHOENIX_POSTGRES_GRAFANA_PASSWORD=grafana_readonly_local_only

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=agentdesk-local-observability
GRAFANA_HOST_PORT=3001

PHOENIX_HTTP_PORT=6006
PHOENIX_OTLP_GRPC_PORT=4317
PHOENIX_PROMETHEUS_PORT=9090

# Prometheus (the real scraper/alerting server, distinct from Phoenix's
# internal :9090 metrics endpoint) and Alertmanager host ports.
PROMETHEUS_HOST_PORT=9091
ALERTMANAGER_HOST_PORT=9093
