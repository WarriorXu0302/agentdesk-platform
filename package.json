{
  "name": "agentdesk-platform",
  "version": "2.0.44",
  "description": "Open enterprise multi-user agent platform — channel ingress, per-user session isolation, frontdesk→worker delegation, and a pluggable backend gateway.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "hooks:install": "git config core.hooksPath git-hooks",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "quickstart": "bash quickstart.sh",
    "typecheck": "tsc --noEmit",
    "init:enterprise": "tsx scripts/init-enterprise-topology.ts",
    "configure:enterprise-gateway": "tsx scripts/configure-enterprise-gateway.ts",
    "obs:up": "docker compose -p agentdesk-observability-prod -f infra/observability/docker-compose.prod.yml up -d",
    "obs:up:prod": "docker compose -p agentdesk-observability-prod -f infra/observability/docker-compose.prod.yml up -d",
    "obs:up:sim": "docker compose -p agentdesk-observability-sim -f infra/observability/docker-compose.sim.yml up -d",
    "obs:down": "docker compose -p agentdesk-observability-prod -f infra/observability/docker-compose.prod.yml down",
    "obs:down:sim": "docker compose -p agentdesk-observability-sim -f infra/observability/docker-compose.sim.yml down",
    "obs:logs": "docker compose -p agentdesk-observability-prod -f infra/observability/docker-compose.prod.yml logs -f",
    "obs:config": "docker compose -p agentdesk-observability-prod -f infra/observability/docker-compose.prod.yml config && docker compose -p agentdesk-observability-sim -f infra/observability/docker-compose.sim.yml config",
    "obs:reset": "docker compose -p agentdesk-observability-prod -f infra/observability/docker-compose.prod.yml down -v",
    "obs:coverage": "vitest run scripts/observability-coverage.test.ts",
    "obs:rules:check": "docker run --rm --entrypoint promtool -v \"$PWD/infra/observability/prometheus:/work\" prom/prometheus:v2.54.1 check rules /work/alerts.yml",
    "obs:runbook:check": "vitest run scripts/runbook-consistency.test.ts",
    "obs:alertmanager:check": "tsx scripts/check-alertmanager.ts",
    "container:build": "bash container/build.sh",
    "e2e:container": "tsx scripts/e2e-container-roundtrip.ts",
    "chat": "tsx scripts/chat.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "pnpm audit --prod --audit-level high"
  },
  "dependencies": {
    "@arizeai/openinference-core": "^2.2.0",
    "@arizeai/openinference-semantic-conventions": "^2.5.0",
    "@larksuiteoapi/node-sdk": "1.66.1",
    "@onecli-sh/sdk": "^0.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "better-sqlite3": "11.10.0",
    "chat": "^4.30.0",
    "cron-parser": "5.5.0",
    "prom-client": "15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.9.3",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.16.0",
      "ws": "^8.20.1",
      "qs": "^6.15.2",
      "protobufjs": "^7.5.8"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-w5hq-g745-h8pq"
      ]
    }
  }
}
