{
  "name": "frontlane-agent-platform",
  "version": "2.0.44",
  "description": "Enterprise multi-user frontdesk and worker agent platform for Feishu + ERP backends.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "init:enterprise": "tsx scripts/init-enterprise-topology.ts",
    "configure:enterprise-gateway": "tsx scripts/configure-enterprise-gateway.ts",
    "generate:env-local-proposed": "tsx scripts/generate-env-local-proposed.ts",
    "setup:lab-frontdesk": "pnpm init:enterprise && pnpm configure:enterprise-gateway && pnpm generate:env-local-proposed",
    "container:build": "bash container/build.sh",
    "chat": "tsx scripts/chat.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "1.63.1",
    "@onecli-sh/sdk": "^0.5.0",
    "better-sqlite3": "11.10.0",
    "chat": "^4.24.0",
    "cron-parser": "5.5.0",
    "prom-client": "15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
