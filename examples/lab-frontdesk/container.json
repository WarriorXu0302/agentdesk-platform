{
  "mcpServers": {},
  "backendGateway": {
    "baseUrl": "http://localhost:8088",
    "timeoutMs": 30000,
    "defaultHeaders": {
      "X-Agent-Source": "lab-frontdesk"
    }
  },
  "packages": {
    "apt": [],
    "npm": []
  },
  "additionalMounts": [],
  "skills": "all",
  "memoryMode": "gateway",
  "a2aSessionMode": "root-session",
  "maxMessagesPerPrompt": 10,
  "resources": {
    "memoryMb": 1024,
    "cpus": 1,
    "pidsLimit": 512
  }
}
