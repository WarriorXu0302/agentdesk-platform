# ============================================================================
# AgentDesk Agent Platform — environment variable reference (.env.example)
# ============================================================================
#
# This file is the single source of truth for every environment variable the
# host and the agent-runner container read. Copy it to `.env` and fill in the
# values your deployment needs:
#
#     cp .env.example .env
#
# Rules of the road
# -----------------
# - The host parses `.env` itself (src/env.ts readEnvFile). It does NOT load
#   secrets into process.env — they are forwarded only to the processes that
#   need them. Keep real secrets in `.env` (gitignored), never in this file.
# - "Required" below means required *only when the related feature is enabled*.
#   A minimal CLI-only deployment needs almost none of these. The host applies
#   conservative fail-fast checks (src/config-validate.ts, ADR-0025): it only
#   demands a variable when the feature that needs it is actually turned on.
# - Secret placeholders here use obvious sentinels like `replace-me-...` /
#   `your-...`. Those exact strings are also baked into
#   src/security/known-weak-secrets.ts — booting with one of them in a
#   security-critical slot is a hard startup error, not a warning. Always
#   replace them with real random values.
# - Machine-derived values (CONTAINER_IMAGE, etc.) are normally computed from
#   BRAND_NAMESPACE at build/run time. Only set them by hand if you know why.
#
# Generate a strong secret:    openssl rand -hex 32
# ============================================================================


# ---------------------------------------------------------------------------
# Branding / namespace  (src/branding.ts — single source of truth)
# ---------------------------------------------------------------------------
# Human-facing platform name (logs, banners, default assistant name).
# Required: no   Default: AgentDesk
BRAND_NAME=AgentDesk
# Machine namespace: a DNS/label-safe slug ([a-z0-9-]). Derives container
# labels, image base, HMAC header prefix, metric prefix, ~/.config/<ns>/ paths,
# MCP server name. Read once at process start; treat as stable for the process.
# Required: no   Default: agentdesk
BRAND_NAMESPACE=agentdesk
# Display name of the assistant the platform presents.
# Required: no   Default: derived from BRAND_NAME
ASSISTANT_NAME=
# Whether the assistant owns its own phone/channel number (affects mention
# handling). Required: no   Default: false
ASSISTANT_HAS_OWN_NUMBER=false


# ---------------------------------------------------------------------------
# Feishu channel  (src/channels/feishu.ts)
# ---------------------------------------------------------------------------
# Feishu/Lark app credentials. If you set FEISHU_APP_ID you MUST also set
# FEISHU_APP_SECRET (and vice versa) — the host fails fast on a half-configured
# pair, because a lone app id can never authenticate.
# Required: yes (when using the Feishu channel)   Default: none
FEISHU_APP_ID=cli_your-feishu-app-id
# SECURITY: this is the app's secret. Leaking it lets an attacker impersonate
# your bot. Required: yes (with FEISHU_APP_ID)   Default: none
FEISHU_APP_SECRET=your-feishu-app-secret
# Bot identity for mention/self-message detection.
# Required: no   Default: none
FEISHU_BOT_OPEN_ID=ou_your-feishu-bot-open-id
FEISHU_BOT_NAME=
# Event delivery mode: webhook | long-connection | hybrid.
# Required: no   Default: long-connection
FEISHU_EVENT_MODE=long-connection
# SECURITY: webhook payload decryption + callback verification. In webhook or
# hybrid mode these are REQUIRED — without them signature verification can
# never succeed and every inbound event is rejected (or, worse, accepted
# unverified if you bypass it). Leaking them lets an attacker forge events.
# Required: yes (webhook/hybrid mode)   Default: none
FEISHU_ENCRYPT_KEY=replace-me-feishu-encrypt-key
FEISHU_VERIFICATION_TOKEN=replace-me-feishu-verification-token
# Feishu API base + tuning. Required: no   Defaults shown.
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_WEBHOOK_PATH=/feishu/webhook
FEISHU_REQUEST_TIMEOUT_MS=30000
FEISHU_BODY_TIMEOUT_MS=30000
FEISHU_MAX_BODY_BYTES=1048576


# ---------------------------------------------------------------------------
# Provider — Claude (Anthropic-compatible)
# ---------------------------------------------------------------------------
# Custom Anthropic-compatible endpoint. When set, the host forwards it into the
# container and the real auth token is rewritten on the wire by OneCLI (the
# token never enters the container). Leave unset for standard api.anthropic.com.
# Required: no   Default: none
ANTHROPIC_BASE_URL=


# ---------------------------------------------------------------------------
# Provider — OpenAI-compatible (Responses API)
# ---------------------------------------------------------------------------
# Used when a session/agent_group/container.json selects provider "openai" or
# "codex". If a provider is set to openai you MUST set OPENAI_API_KEY. The host
# treats "any OPENAI_* var set but OPENAI_API_KEY missing" as openai-configured
# and fails fast.
# OpenAI-compatible gateway base URL. Required: yes (openai provider)
OPENAI_BASE_URL=https://your-llm-gateway.example.com/v1
# SECURITY: API credential forwarded into the container. Leaking it allows
# unauthorized model usage on your account/gateway.
# Required: yes (openai provider)   Default: none
OPENAI_API_KEY=sk-your-openai-api-key
# Model + tuning. Required: no (model has a built-in default)   Defaults vary.
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=
OPENAI_TIMEOUT_MS=
OPENAI_FORCE_TRANSPORT=
# Summary-based context compaction (ADR-0024). Optional; falls back to
# OPENAI_MODEL / archiving-off when unset. Required: no
OPENAI_COMPACT_MODEL=
OPENAI_COMPACT_ARCHIVE=
# SECURITY: route the openai/codex provider through the OneCLI vault instead of
# handing OPENAI_API_KEY to the container (ADR-0035). Default OFF. When 'true':
# the key is NOT injected into the container; the container posts to the real
# OpenAI endpoint through the vault's HTTPS_PROXY and the vault injects the
# Authorization header (same mechanism the Claude provider already uses). The
# default Claude provider is unaffected (already key-out-of-container).
# PRECONDITION: your OneCLI vault must be configured to inject an OpenAI
# credential — otherwise calls fail closed with 401 (no key leak, just failure).
# Required: no   Default: false (key forwarded to container, as before)
AGENTDESK_OPENAI_VIA_ONECLI=


# ---------------------------------------------------------------------------
# OneCLI proxy  (auth/secret rewriting on the wire)
# ---------------------------------------------------------------------------
# OneCLI proxy endpoint. Required: no (only when using OneCLI secret rewrite)
ONECLI_URL=
# SECURITY: API key for the OneCLI control plane. Leaking it exposes every
# secret OneCLI fronts. Required: yes (when ONECLI_URL is set)   Default: none
ONECLI_API_KEY=replace-me-onecli-api-key


# ---------------------------------------------------------------------------
# Backend gateway  (auth / execute / long-term memory — the only path)
# ---------------------------------------------------------------------------
# Default gateway base URL used by scripts/configure-enterprise-gateway.ts when
# --base-url is omitted. This is the LIVE variable — prefer it.
# Required: no (the configure script can also take --base-url)   Default: none
GATEWAY_BASE_URL=https://your-gateway.example.com/api/agent
# DEPRECATED ALIAS — legacy from the erp→gateway generalization. Still read as
# a fallback by scripts/configure-enterprise-gateway.ts only. Prefer
# GATEWAY_BASE_URL; this exists for backward compatibility and may be removed.
# Required: no   Default: none
# ERP_GATEWAY_BASE_URL=
# SECURITY: HMAC request-signing key (ADR-0018). When a group's gateway has a
# baseUrl but no signing key, requests go out UNSIGNED and anything that can
# reach the gateway can forge a host-provisioned container. This is the
# strongest knob in the trust chain — generate with: openssl rand -hex 32.
# Required: strongly recommended in production   Default: none (unsigned)
GATEWAY_SIGNING_KEY=replace-me-openssl-rand-hex-32

# SECURITY: Host-side gateway signing credential proxy (ADR-0034). Default OFF.
# When 'true', the backend signingKey is NOT mounted into agent containers —
# the host mints a per-session, scoped, revocable token, mounts a redacted
# container.json (no signingKey, blanked baseUrl), and signs gateway requests on
# the container's behalf via a local proxy. Removes the "injected container can
# read the long-lived signing key" exposure (ADR-0032 egress only mitigated it).
# Deployment note: in proxy mode, container egress MUST allow the container ->
# host proxy port (and ideally only that). signingKey must still be configured
# per group (the host reads it to sign). Linux is the intended target — on
# Docker Desktop / NAT the source-IP pin can't tell containers apart.
# Required: no   Default: false (byte-for-byte unchanged behavior)
AGENTDESK_GATEWAY_SIGNING_PROXY=
# Proxy listener port (container reaches it at host.docker.internal:<port>).
# Required: no   Default: 8799
AGENTDESK_GATEWAY_SIGNING_PROXY_PORT=
# Interface to bind. Default 0.0.0.0 so containers can reach it via the docker
# gateway; firewall it to the docker bridge in production.
# Required: no   Default: 0.0.0.0
AGENTDESK_GATEWAY_SIGNING_PROXY_BIND=
# Per-session token TTL (ms). Backstop only — tokens are revoked at container
# exit. Required: no   Default: 3600000 (1h)
AGENTDESK_GATEWAY_SIGNING_PROXY_TTL_MS=
# Per-token rate limit (requests per window) and window (ms).
# Required: no   Default: 600 per 60000ms
AGENTDESK_GATEWAY_SIGNING_PROXY_RATE=
AGENTDESK_GATEWAY_SIGNING_PROXY_RATE_WINDOW_MS=
# Max request body bytes the proxy will accept. Required: no   Default: 1048576
AGENTDESK_GATEWAY_SIGNING_PROXY_MAX_BODY_BYTES=


# ---------------------------------------------------------------------------
# Enterprise autowire  (scripts/init-enterprise-topology.ts + autowire)
# ---------------------------------------------------------------------------
# Frontdesk agent_group folder the autowire path targets.
# Required: no   Default: <namespace>-frontdesk
ENTERPRISE_FRONTDESK_FOLDER=agentdesk-frontdesk
# Which channels to auto-wire. Required: no   Default: none
ENTERPRISE_AUTO_WIRE_CHANNELS=feishu
# Auto-wire Feishu P2P (1:1) chats. Required: no   Default: false
ENTERPRISE_AUTO_WIRE_P2P=false
# Auto-wire Feishu group chats (conservative; keep off unless needed).
# Required: no   Default: false
ENTERPRISE_AUTO_WIRE_GROUPS=false
# Session mode for auto-wired group chats. Required: no   Default: per-thread
ENTERPRISE_AUTO_WIRE_GROUP_SESSION_MODE=
# Whether autowire may downgrade unknown_sender_policy. Required: no  Default: true
ENTERPRISE_AUTO_WIRE_ALLOW_POLICY_DOWNGRADE=true


# ---------------------------------------------------------------------------
# Container runtime & capacity  (strongly recommended in production)
# ---------------------------------------------------------------------------
# Container image. MACHINE-DERIVED from BRAND_NAMESPACE — normally auto-derived,
# do NOT set by hand unless you know why. Required: no
# CONTAINER_IMAGE=
# CONTAINER_IMAGE_BASE=
# Container runtime binary (docker | podman | ...). Required: no  Default: docker
CONTAINER_RUNTIME=
# Global concurrent-container cap (backpressure). Required: no   Default: 10
MAX_CONCURRENT_CONTAINERS=10
# Per-prompt message batching cap. Required: no   Default: provider-specific
MAX_MESSAGES_PER_PROMPT=
# Max captured container stdout/stderr bytes. Required: no   Default: built-in
CONTAINER_MAX_OUTPUT_SIZE=
# Per-run hard timeout for a container. Required: no   Default: built-in
CONTAINER_TIMEOUT=
# Idle-exit timeout (ms) — container self-exits after this idle. 0 = off.
# Required: no   Default: 0
AGENTDESK_IDLE_EXIT_MS=0
# Legacy idle-timeout alias. Required: no
IDLE_TIMEOUT=
# Max a2a spawn depth (loop guard). Required: no   Default: built-in
AGENTDESK_MAX_SPAWN_DEPTH=
# Session archival / hard-delete TTLs (days). 0 = off.
# Required: no   Default: 0
AGENTDESK_SESSION_TTL_DAYS=0
AGENTDESK_ARCHIVE_HARD_DELETE_DAYS=0
# Audit retention (days). 0 = OFF (default — audit rows are NEVER deleted
# silently). When > 0, host-sweep trims gateway_audit rows older than this many
# days (the table grows per gateway call, incl. the signing proxy). Set per your
# compliance/retention policy. Required: no   Default: 0 (keep forever)
AGENTDESK_AUDIT_RETAIN_DAYS=0
# HMAC-SHA256 key for signing compliance audit exports (scripts/export-audit.ts,
# roadmap 5.4). When set, exported bundles carry a signature so an auditor can
# verify they weren't altered after export. Unset = exports are produced but
# UNSIGNED (the tool warns). Required: no   Default: unset (unsigned)
# AGENTDESK_AUDIT_EXPORT_KEY=change-me-to-a-long-random-secret
# Runaway-cost ceiling: max LLM tokens a single session may spend per minute
# (summed over a trailing 5-min window from outbound.db llm-usage rows). 0 = OFF
# (default). When > 0, host-sweep KILLS a running session that blows past it —
# catching a looping/prompt-injected agent that keeps its heartbeat fresh while
# burning tokens (the heartbeat/claim stuck-checks can't see that). Pick a value
# comfortably above a legitimate heavy turn so you don't kill real work.
# Required: no   Default: 0 (disabled)
AGENTDESK_SESSION_TOKEN_BUDGET_PER_MIN=0
# Central DB fsync durability: NORMAL (default) is durable across an app crash;
# set FULL to fsync every commit (durable across host power loss, slower writes).
# Required: no   Default: NORMAL
AGENTDESK_DB_SYNCHRONOUS=
# Container build-time toggles (Dockerfile args; not runtime host vars).
# INSTALL_CJK_FONTS=1 bakes CJK fonts in; BUN_VERSION pins the Bun toolchain.
# Required: no   Defaults set in container/Dockerfile.
# INSTALL_CJK_FONTS=
# BUN_VERSION=


# ---------------------------------------------------------------------------
# Delivery  (outbound to channels)
# ---------------------------------------------------------------------------
# Per-delivery adapter-call timeout (ms). Required: no   Default: 30000
DELIVERY_TIMEOUT_MS=30000
# Cross-session delivery concurrency (in-session stays serial).
# Required: no   Default: 4
DELIVERY_CONCURRENCY=4
# Inbound durability mode (persist-before-route, ADR-0022). Required: no
INGRESS_DURABILITY=


# ---------------------------------------------------------------------------
# Webhook server  (shared port for webhook + /metrics + /healthz + /readyz)
# ---------------------------------------------------------------------------
# Required: yes (webhook mode)   Default: 3000
WEBHOOK_PORT=3000
# Ingress body size cap (bytes); over-limit → 413. Required: no  Default: 1048576
WEBHOOK_MAX_BODY_BYTES=1048576
# Slow-loris / slow-request protection (ms). Required: no   Defaults shown.
WEBHOOK_REQUEST_TIMEOUT_MS=30000
WEBHOOK_HEADERS_TIMEOUT_MS=10000
# Grace period for closing connections at shutdown (ms). Required: no
WEBHOOK_CLOSE_GRACE_MS=


# ---------------------------------------------------------------------------
# Observability  (read-only — never mutates the trust chain)
# ---------------------------------------------------------------------------
# SECURITY: when set, /metrics requires `Authorization: Bearer <token>` (else
# 401). Unset = /metrics is PUBLIC. Set this, or isolate /metrics behind a
# reverse proxy, in production. Required: recommended   Default: none (public)
METRICS_AUTH_TOKEN=replace-me-metrics-auth-token
# OpenTelemetry. Required: no   Defaults: SDK on, derived service name.
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_SDK_DISABLED=
OTEL_SERVICE_NAME=
# Full-plaintext trace content capture (ADR-0027). Required: no   Default: OFF.
# !!! DANGER — READ BEFORE ENABLING !!!
# When set to 'true', the runner writes FULL PLAINTEXT into your traces (Phoenix):
#   - chat message bodies (user input + agent final reply)
#   - complete LLM input/output messages (system prompt, history, completion)
#   - MCP tool call arguments AND tool result text (incl. gateway/ERP payloads)
# This is NOT redacted/scrubbed — only a 50000-char per-attribute cap guards the
# OTLP exporter from oversized payloads (truncation marker, not privacy).
# Enable ONLY if you run your OWN private Phoenix on a controlled internal
# network and accept full responsibility for the data-compliance of putting
# business content into your trace backend.
# The open-source baseline keeps this OFF: left commented out below so that
# `cp .env.example .env` does NOT silently turn full-plaintext capture on. The
# host emits a startup warning (src/config-validate.ts) whenever it sees a truthy
# value here. Uncomment and set to 'true' ONLY after reading the danger note above.
# OTEL_CAPTURE_CONTENT=true
# Log verbosity: debug | info | warn | error. Required: no   Default: info
LOG_LEVEL=info


# ---------------------------------------------------------------------------
# Roster DM  (host-mediated, consent-gated directed messaging — ADR-0023)
# ---------------------------------------------------------------------------
# Master switch for the roster-DM feature. Required: no   Default: false (off)
ALLOW_ROSTER_DM=false
# Re-check channel membership before sending a DM. Required: no   Default: on
ROSTER_VERIFY_MEMBERSHIP=
# Let the gateway be the authority for DM grants. Required: no   Default: off
ROSTER_GATEWAY_AUTHORITY=
# Per-day cap on roster-driven deploys. Required: no   Default: built-in
ROSTER_DEPLOY_DAILY_CAP=
# Progress reaction/status display config. Required: no   Defaults shown.
AGENTDESK_PROGRESS_STATUS_CHANNELS=feishu
AGENTDESK_PROGRESS_STATUS_FEISHU_EMOJI=


# ---------------------------------------------------------------------------
# Security switches  (fail-closed by default — ADR-0019)
# ---------------------------------------------------------------------------
# Escape hatch: allow admin commands when the user_roles table is absent.
# Leaving this UNSET keeps the fail-closed default (admin denied without roles).
# Only set to true in trusted single-tenant setups. Required: no  Default: unset
ALLOW_ADMIN_WITHOUT_ROLES=


# ---------------------------------------------------------------------------
# Misc / runtime
# ---------------------------------------------------------------------------
# node | development | production. Required: no   Default: undefined
NODE_ENV=
# IANA timezone for the host and forwarded to containers. Required: no
TZ=
# Graceful-shutdown hard deadline (ms). Required: no   Default: 20000
SHUTDOWN_DEADLINE_MS=20000
# Claude Code auto-compaction window (container-side). Required: no
CLAUDE_CODE_AUTO_COMPACT_WINDOW=
