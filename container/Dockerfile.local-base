#
# Local fallback image for FrontLane agent-runner.
#
# Use this when Docker Hub is unreachable but you already have a local
# Node-based image available. It is intentionally minimal:
# - installs Bun
# - installs agent-runner deps
# - relies on FrontLane's host-side bind mounts for /app/src and /app/skills
#
# Example:
#   docker build \
#     --build-arg BASE_IMAGE=saleagent-frontend:latest \
#     -t nanoclaw-agent-v2-<slug>:latest \
#     -f container/Dockerfile.local-base \
#     container

ARG BASE_IMAGE=saleagent-frontend:latest
FROM ${BASE_IMAGE}

ARG BUN_VERSION=1.3.12

RUN apk add --no-cache bash curl git ca-certificates

RUN curl -fsSL https://bun.sh/install | bash -s "bun-v${BUN_VERSION}" && \
    install -m 0755 /root/.bun/bin/bun /usr/local/bin/bun && \
    rm -rf /root/.bun

WORKDIR /app

COPY agent-runner/package.json agent-runner/bun.lock ./

RUN bun install --frozen-lockfile

RUN mkdir -p /workspace/group /workspace/extra /home/node/.claude && \
    chmod -R 777 /workspace /home/node

WORKDIR /workspace/group
